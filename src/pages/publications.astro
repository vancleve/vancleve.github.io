---
import Layout from '../layouts/Layout.astro';
import CSL from 'citeproc';
import type { Data as CSLItem } from 'csl-json';

const ZOTERO_USER_ID = '2209856';
const ZOTERO_COLLECTION_KEY = 'ISBLYB53';
const CITATION_STYLE = 'genetics';

const apiKey = import.meta.env.ZOTERO_API_KEY;

// For items with a DOI, strip URL and accessed fields.
function preprocessItem(item: CSLItem): CSLItem {
  if (item.DOI) {
    const { URL: _url, accessed: _accessed, 'collection-title': _series, ...rest } = item;
    return rest as CSLItem;
  }
  return item;
}

async function fetchCSLItems(): Promise<CSLItem[]> {
  const headers: Record<string, string> = { 'Zotero-API-Version': '3' };
  if (apiKey) headers['Authorization'] = `Bearer ${apiKey}`;

  const items: CSLItem[] = [];
  const limit = 100;
  let start = 0;

  while (true) {
    const url = new URL(
      `https://api.zotero.org/users/${ZOTERO_USER_ID}/collections/${ZOTERO_COLLECTION_KEY}/items/top`
    );
    url.searchParams.set('format', 'json');
    url.searchParams.set('include', 'csljson');
    url.searchParams.set('itemType', 'journalArticle || bookSection || book');
    url.searchParams.set('sort', 'date');
    url.searchParams.set('direction', 'desc');
    url.searchParams.set('limit', String(limit));
    url.searchParams.set('start', String(start));

    const res = await fetch(url, { headers });
    if (!res.ok) throw new Error(`Zotero API ${res.status}: ${await res.text()}`);

    const total = parseInt(res.headers.get('Total-Results') ?? '0', 10);
    const page: Array<{ csljson: CSLItem }> = await res.json();
    items.push(...page.map((p) => preprocessItem(p.csljson)));
    start += limit;
    if (start >= total) break;
  }

  return items;
}

async function fetchText(url: string): Promise<string> {
  const res = await fetch(url);
  if (!res.ok) throw new Error(`Failed to fetch ${url}: ${res.status}`);
  return res.text();
}

// The Genetics journal style is a dependent CSL that inherits from cse-name-year
const CSL_PARENT_STYLE = 'cse-name-year';

const [cslItems, styleXML, localeXML] = await Promise.all([
  fetchCSLItems(),
  fetchText(
    `https://raw.githubusercontent.com/citation-style-language/styles/master/${CSL_PARENT_STYLE}.csl`
  ),
  fetchText(
    'https://raw.githubusercontent.com/citation-style-language/locales/master/locales-en-US.xml'
  ),
]);

const itemMap = new Map(cslItems.map((item) => [String(item.id), item]));

const engine = new CSL.Engine(
  {
    retrieveLocale: (_lang: string) => localeXML,
    retrieveItem: (id: string) => itemMap.get(id)!,
  },
  styleXML
);

engine.updateUncitedItems([...itemMap.keys()]);
const [bibParams, rawEntries] = engine.makeBibliography() as [
  { entry_ids: Array<string[]> },
  string[]
];

// Strip the outer <div class="csl-entry"> wrapper and turn all bare URLs into links.
// Negative lookbehind avoids double-wrapping URLs already in href="..." attributes.
// Trailing punctuation (period, comma, etc.) is excluded from the link target.
function processEntry(html: string): string {
  const inner =
    html.match(/<div class="csl-entry">(.*?)<\/div>\s*$/s)?.[1]?.trim() ?? html;
  return inner.replace(
    /(?<![="'])https?:\/\/[^\s<"']+/g,
    (raw) => {
      const url = raw.replace(/[.,;:!?]+$/, '');
      const trail = raw.slice(url.length);
      return `<a href="${url}" target="_blank" rel="noopener">${url}</a>${trail}`;
    }
  );
}

// Build id → formatted-entry map so we can reimpose the Zotero sort order
const entryMap = new Map<string, string>(
  bibParams.entry_ids.map((ids, i) => [String(ids[0]), processEntry(rawEntries[i])])
);

// Preserve the reverse-chronological order returned by the Zotero API
const publications = cslItems
  .map((item) => entryMap.get(String(item.id)))
  .filter((html): html is string => html !== undefined);
---
<Layout title="Publications" currentPage="publications">
  <ul class="pub-list">
    {publications.map((html) => <li set:html={html} />)}
  </ul>
</Layout>
