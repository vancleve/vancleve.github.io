---
import { Image } from 'astro:assets';
import '../styles/global.css';
import heronImg from '../assets/images/heron.png';

interface Props {
  title?: string;
  currentPage?: string;
}

const { title, currentPage } = Astro.props;
const pageTitle = title ? `${title} | van cleve research group` : 'van cleve research group';

const navLinks = [
  { href: '/research/',      label: 'Research' },
  { href: '/publications/',  label: 'Publications' },
  { href: '/teaching/',      label: 'Teaching' },
  { href: '/people/',        label: 'People' },
  { href: '/software/',      label: 'Software' },
  { href: '/join/',          label: 'Join' },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Van Cleve Research Group – theoretical evolution & ecology at the University of Kentucky" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{pageTitle}</title>
</head>
<body>
  <div class="site-wrapper">
    <header class="site-header">
      <div class="header-top">
        <div class="header-brand">
          <a href="/"><p class="site-title">van cleve research group</p></a>
          <p class="site-tagline">theoretical evolution &amp; ecology @ university of kentucky</p>
        </div>
        <Image src={heronImg} alt="an integral of the 'heron' function" class="header-heron" />
      </div>
      <nav class="primary" aria-label="Primary navigation">
        <ul>
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                aria-current={currentPage === link.label.toLowerCase() ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <div class="site-body">
      <main>
        <slot />
      </main>

      <aside class="sidebar">
        <p class="sidebar-section-title">Links</p>
        <ul>
          <li><a href="http://scholar.google.com/citations?user=-F-MKiQAAAAJ" target="_blank" rel="noopener">Google Scholar</a></li>
          <li><a href="http://github.com/vancleve" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://bsky.app/profile/vancleve.theoretical.bio" target="_blank" rel="noopener">Bluesky</a></li>
          <li><a href="http://bio.as.uky.edu/" target="_blank" rel="noopener">UK Biology</a></li>
          <li><a href="mailto:jvancleve@uky.edu">E-mail</a></li>
        </ul>
      </aside>
    </div>

    <footer class="site-footer">
      &copy; van cleve research group
    </footer>
  </div>
</body>
</html>
